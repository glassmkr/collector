{
  "name": "@glassmkr/crucible",
  "version": "0.10.0",
  "description": "Lightweight bare metal server monitoring. IPMI, SMART, OS, network. Opinionated alerts.",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./api": {
      "types": "./dist/api.d.ts",
      "default": "./dist/api.js"
    },
    "./rule-ids.json": "./rule-ids.json",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "rule-ids.json",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "glassmkr-crucible": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && chmod 755 dist/index.js",
    "start": "node dist/index.js",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "monitoring",
    "bare-metal",
    "ipmi",
    "smart",
    "server",
    "alerts"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/glassmkr/crucible.git"
  },
  "dependencies": {
    "yaml": "^2.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.4"
  }
}
